---
import { Icon } from 'astro-icon/components';
---

<a class="link" href="tel:+33603155113">
  <Icon name="phone" />
  <span>+33 6 03 15 51 13</span>
</a>

<style>
  a {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
  }

  span {
    display: none;
  }

  [data-icon] {
    height: 0.75rem;
  }

  @media screen and (min-width: 900px) {
    span {
      display: block;
      font-family: var(--font-secondary), sans-serif;
      font-size: var(--font-size-14);
    }
  }
</style>
