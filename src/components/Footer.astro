---
import { Icon } from 'astro-icon/components';
---

<footer>
  <span class="fullname">Victor BETSCH</span>
  <address>
    <a class="link" href="tel:+33603155113">
      <Icon name="phone" />
      <span>+33 6 03 15 51 13</span>
    </a>
    <a class="link" href="mailto:vbetsch.contact@gmail.com">
      <Icon name="email" />
      <span>vbetsch.contact@gmail.com</span>
    </a>
    <a class="link" href="https://www.linkedin.com/in/vbetsch" target="_blank">
      <Icon name="linkedin" />
      <span>vbetsch</span>
    </a>
    <a class="link" href="https://github.com/vbetsch" target="_blank">
      <Icon name="github" />
      <span>vbetsch</span>
    </a>
  </address>
</footer>

<style>
  footer {
    background-color: var(--color-grey-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
  }

  .fullname {
    white-space: nowrap;
    font-family: var(--font-mono), sans-serif;
    font-size: var(--font-size-12);
  }

  address {
    display: flex;
    gap: clamp(1rem, 7vw, 3rem);
  }

  address a {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
  }

  address span {
    display: none;
  }

  [data-icon] {
    height: 0.75rem;
  }

  @media screen and (min-width: 900px) {
    address span {
      display: block;
      font-family: var(--font-secondary), sans-serif;
      font-size: var(--font-size-14);
    }
  }
</style>
