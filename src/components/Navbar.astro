---
import ContactMe from '@components/ContactMe.astro';
---

<header>
  <nav id="navbar">
    <div class="content">
      <a class="fullname" href="#navbar">
        Victor <b>BETSCH</b>
      </a>
      <ContactMe />
    </div>
  </nav>
</header>

<style>
  header {
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  #navbar {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .content {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
</style>
