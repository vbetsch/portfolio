---
import { Icon } from 'astro-icon/components';

export type Props = {
  href: string;
  iconName: string;
  label: string;
  openNewTab?: boolean | null;
};

const defaults: Partial<Props> = { openNewTab: false };

const props: Props = { ...defaults, ...Astro.props };
---

<a
  href={props.href}
  target={props.openNewTab ? '_blank' : null}
  rel={props.openNewTab ? 'noopener noreferrer' : null}
>
  <Icon name={props.iconName} />
  <span>{props.label}</span>
</a>

<style>
  a {
    display: flex;
    align-items: center;
    gap: var(--size-6);
  }

  span {
    display: none;
  }

  [data-icon] {
    width: var(--size-14);
  }

  @media screen and (min-width: 900px) {
    span {
      display: block;
      font-family: var(--font-secondary), sans-serif;
      font-size: var(--size-14);
    }
  }
</style>
