---
import AddressLink from '@components/body/footer/AddressLink.astro';
---

<footer>
  <span class="fullname">Victor BETSCH</span>
  <address>
    <AddressLink href="tel:+33603155113" iconName="phone" label="+33 6 03 15 51 13" />
    <AddressLink
      href="mailto:vbetsch.contact@gmail.com"
      iconName="email"
      label="vbetsch.contact@gmail.com"
    />
    <AddressLink
      href="https://www.linkedin.com/in/vbetsch"
      iconName="linkedin"
      label="vbetsch"
      openNewTab
    />
    <AddressLink href="https://github.com/vbetsch" iconName="github" label="vbetsch" openNewTab />
  </address>
</footer>

<style>
  footer {
    background-color: var(--color-grey-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
  }

  .fullname {
    white-space: nowrap;
    font-family: var(--font-mono), sans-serif;
    font-size: var(--font-size-12);
  }

  address {
    display: flex;
    gap: clamp(1rem, 7vw, 3rem);
  }
</style>
