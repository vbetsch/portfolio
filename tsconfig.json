{
  "exclude": [
    "**/coverage/**",
    "**/dist/**",
    "**/node_modules/**",
    "**/playwright-report/**",
    "**/test-results/**",
    "**/vitest-report/**"
  ],
  "extends": [
    "@vbetsch/config-tsconfig/base",
    "@vbetsch/config-tsconfig/strict",
    "@vbetsch/config-tsconfig/jsx",
    "astro/tsconfigs/strict"
  ],
  /* Overrides */
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@data/*": ["./src/data/*"],
      "@enums/*": ["./src/enums/*"],
      "@tests/*": ["./tests/*"],
      "@utils/*": ["./src/utils/*"]
    },
    "plugins": [{ "name": "@astrojs/ts-plugin" }]
  },
  "include": [".astro/types.d.ts", "**/*"]
}
