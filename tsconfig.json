{
  "exclude": ["**/node_modules/**", "**/dist/**", "**/coverage/**"],
  "extends": [
    "@vbetsch/config-tsconfig/base",
    "@vbetsch/config-tsconfig/strict",
    "@vbetsch/config-tsconfig/jsx",
    "astro/tsconfigs/strict"
  ],
  /* Overrides */
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"]
}
